            else
                Rayfield:Notify({
                    Title = "Error",
                    Content = "Invalid key.",
                    Duration = 2
                })
            end
        end)
        
        if not success then
            print("Callback error: " .. tostring(err))
            Rayfield:Notify({
                Title = "Error",
                Content = "Callback failed: " .. tostring(err),
                Duration = 5
            })
        end
    end
